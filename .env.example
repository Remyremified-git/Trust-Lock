DATABASE_URL="postgresql://avnadmin:<PASSWORD>@<AIVEN_HOST>:<PORT>/defaultdb?sslmode=require"
APP_BASE_URL="http://localhost:3000"

# Clerk (required)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxx"
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxx"

# Optional: custom Clerk routes if you want dedicated pages
