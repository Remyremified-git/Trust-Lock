# Primary DB variable used by Prisma/app runtime.
# For Aiven, paste the full connection URI here and ensure sslmode=require.
DATABASE_URL="postgresql://avnadmin:<PASSWORD>@<AIVEN_HOST>:<PORT>/defaultdb?sslmode=require"

# Optional alias supported by the app. If DATABASE_URL is empty, this is used.
AIVEN_DATABASE_URL=""

# Optional Vercel Postgres aliases also supported as fallback:
# POSTGRES_PRISMA_URL=""
# POSTGRES_URL=""
# POSTGRES_URL_NON_POOLING=""

APP_BASE_URL="http://localhost:3000"

# 64 hex chars (32 bytes) for AES-256-GCM at-rest encryption
ADMIN_VAULT_AT_REST_KEY="replace_with_64_hex_chars"
AUTH_DATA_AT_REST_KEY="replace_with_64_hex_chars_for_auth_mfa_linking_data"

# Admin API hard gate token used in x-admin-token header
ADMIN_API_TOKEN="replace_with_long_random_admin_token"
AUTH_SESSION_SECRET="replace_with_long_random_session_secret"
AUTH_SESSION_TTL_DAYS="14"
AUTH_REQUIRE_VERIFIED_EMAIL="false"

# RSA keypair for transport encryption
# Keep multiline PEM format with real line breaks.
ADMIN_SEED_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\nREPLACE\n-----END PUBLIC KEY-----"
ADMIN_SEED_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\nREPLACE\n-----END PRIVATE KEY-----"

# Shared rate limiting (optional; falls back to in-memory when not set)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# SMTP for real email delivery (optional; falls back to console preview logs)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="security@hybrid-vault.local"

# WebAuthn / Passkeys
WEBAUTHN_RP_NAME="Hybrid Vault"
WEBAUTHN_RP_ID="localhost"
WEBAUTHN_ORIGINS="http://localhost:3000"
